# Copy to .env.e2e and adjust. Used by `npm run test:e2e` (Playwright).

# Frontend origin (Next.js)
E2E_WEB_URL=http://localhost:3000

# Backend API (must match NEXT_PUBLIC_API_URL used by the FE process)
E2E_API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# SePay IPN secret — must match backend DADIARY_SEPAY_SECRET_KEY
E2E_SEPAY_SECRET_KEY=spsk_test_UHoXRUQEfLBChDYghS6AE8B6V9HQpErZ

# Enables POST /api/v1/internal/e2e/force-plan (expiry smoke).
# Also set the same value on the API: DADIARY_E2E_SECRET=...
E2E_SECRET=local-e2e-secret

# Optional password for generated smoke users
# E2E_USER_PASSWORD=SmokeTest1!
