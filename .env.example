# Public URL of Go API (browser-accessible).
NEXT_PUBLIC_API_URL=http://localhost:8080

# Cloudflare Turnstile (optional local; set with DADIARY_TURNSTILE_SECRET_KEY on API).
# https://dash.cloudflare.com/ → Turnstile → create widget → Site Key (public) + Secret Key (server).
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
